OPENAI_API_KEY=sk-your-openai-api-key-here

# Required for browser-side anonymous Supabase ownership.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for production storage, share links, and database records.
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JOB_ARTIFACTS_BUCKET=cinelife-job-artifacts

# Optional external voice cloning service endpoint, for example a secured F5-TTS
# service. CineLife sends { script, voiceSampleDataUrl, voiceSampleName } and
# expects audio bytes in the response.
VOICE_CLONING_API_URL=https://your-voice-cloning-service.example.com/generate
VOICE_CLONING_API_KEY=your-voice-cloning-service-key

# Optional local F5-TTS cloning. Install with Python 3.11:
#   python3.11 -m venv .venv-f5
#   .venv-f5/bin/pip install f5-tts
# F5-TTS needs the CLI plus model downloads on first use.
F5_TTS_ENABLED=false
F5_TTS_CLI_PATH=/absolute/path/to/.venv-f5/bin/f5-tts_infer-cli
F5_TTS_MODEL=F5TTS_v1_Base
F5_TTS_DEVICE=mps
F5_TTS_TIMEOUT_MS=600000
F5_TTS_SPEED=0.82
F5_TTS_CHUNK_CHARS=420
